{
  "name": "firestore-mobx",
  "version": "3.0.0",
  "description": "Observable Firestore documents and collections using MobX",
  "keywords": [
    "firebase-mobx",
    "firestorable",
    "firestore-collection",
    "firestore-mobx",
    "firestore-react",
    "firestorter",
    "mobx-firestore",
    "react-firebase",
    "react-firestore",
    "react-firestore-mobx"
  ],
  "homepage": "https://firestore-mobx.codecompose.dev",
  "bugs": {
    "url": "https://github.com/0x80/firestore-mobx/issues"
  },
  "license": "MIT",
  "author": "Thijs Koerselman <thijs@vauxlab.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x80/firestore-mobx.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "lint": "oxlint -c .oxlintrc.json",
    "format": "oxfmt",
    "check-format": "oxfmt --check",
    "check-types": "tsc --noEmit",
    "prepare": "pnpm check-types && pnpm build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "firebase": "^11.6.0",
    "mobx": "^6.15.0",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.0",
    "vitepress": "^1.6.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "firebase": ">=10",
    "mobx": ">=6"
  }
}
